{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://iotables.net/schemas/16-research-decisions/background-cache-locking-decision.schema.json",
  "title": "IoTable Background Jobs, Cache, and Locking Decision Schema",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "document",
    "purpose",
    "selected_technologies",
    "research_record",
    "background_job_decision",
    "cache_decision",
    "locking_decision",
    "integration_rules",
    "forbidden_behavior",
    "open_decisions",
    "done_when"
  ],
  "properties": {
    "document": { "$ref": "#/$defs/document" },
    "purpose": { "$ref": "#/$defs/object_record" },
    "selected_technologies": { "$ref": "#/$defs/object_record" },
    "research_record": { "$ref": "#/$defs/research_record" },
    "background_job_decision": { "$ref": "#/$defs/object_record" },
    "cache_decision": { "$ref": "#/$defs/object_record" },
    "locking_decision": { "$ref": "#/$defs/object_record" },
    "integration_rules": { "type": "array", "items": { "$ref": "#/$defs/rule_record" } },
    "forbidden_behavior": { "$ref": "#/$defs/string_array" },
    "open_decisions": { "type": "array" },
    "done_when": { "$ref": "#/$defs/string_array" }
  },
  "$defs": {
    "string_array": { "type": "array", "items": { "type": "string", "minLength": 1 } },
    "object_record": { "type": "object", "additionalProperties": true, "minProperties": 1 },
    "research_record": {
      "type": "object",
      "additionalProperties": false,
      "required": ["decision_id", "topic", "status", "problem", "selected_option", "options", "source_records", "fit_assessment", "risks"],
      "properties": {
        "decision_id": { "type": "string", "minLength": 1 },
        "topic": { "type": "string", "minLength": 1 },
        "status": { "type": "string", "enum": ["accepted", "rejected", "needs_owner_decision", "research_only"] },
        "problem": { "type": "string", "minLength": 1 },
        "selected_option": { "type": "string", "minLength": 1 },
        "options": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/research_option" } },
        "source_records": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/source_record" } },
        "fit_assessment": { "$ref": "#/$defs/object_record" },
        "risks": { "type": "array", "items": { "$ref": "#/$defs/risk_record" } }
      }
    },
    "research_option": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "description", "advantages", "disadvantages", "fit_score", "source_support"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "description": { "type": "string", "minLength": 1 },
        "advantages": { "$ref": "#/$defs/string_array" },
        "disadvantages": { "$ref": "#/$defs/string_array" },
        "fit_score": { "type": "integer", "minimum": 1, "maximum": 5 },
        "source_support": { "$ref": "#/$defs/string_array" }
      }
    },
    "source_record": {
      "type": "object",
      "additionalProperties": false,
      "required": ["source_id", "source_type", "authority_level", "locator", "retrieved_at", "used_for", "extracted_facts", "limitations", "spec_impact"],
      "properties": {
        "source_id": { "type": "string", "minLength": 1 },
        "source_type": { "type": "string", "minLength": 1 },
        "authority_level": { "type": "string", "minLength": 1 },
        "locator": { "type": "string", "minLength": 1 },
        "retrieved_at": { "type": "string", "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$" },
        "used_for": { "$ref": "#/$defs/string_array" },
        "extracted_facts": { "$ref": "#/$defs/string_array" },
        "limitations": { "$ref": "#/$defs/string_array" },
        "spec_impact": { "$ref": "#/$defs/string_array" }
      }
    },
    "risk_record": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "risk", "mitigation"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "risk": { "type": "string", "minLength": 1 },
        "mitigation": { "type": "string", "minLength": 1 }
      }
    },
    "document": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "title", "project", "version", "language", "format", "schema_required", "schema_file", "status"],
      "properties": {
        "id": { "type": "string", "const": "16-research-decisions.background-cache-locking-decision" },
        "title": { "type": "string", "minLength": 1 },
        "project": { "type": "string", "const": "IoTable" },
        "version": { "type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$" },
        "language": { "type": "string", "const": "en" },
        "format": { "type": "string", "const": "yaml" },
        "schema_required": { "type": "boolean", "const": true },
        "schema_file": { "type": "string", "const": "schemas/16-research-decisions/background-cache-locking-decision.schema.json" },
        "status": { "type": "string", "enum": ["draft", "accepted", "superseded"] }
      }
    },
    "rule_record": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "rule"],
      "properties": {
        "id": { "type": "string", "pattern": "^BCL-[0-9]{3}$" },
        "rule": { "type": "string", "minLength": 1 }
      }
    }
  }
}
