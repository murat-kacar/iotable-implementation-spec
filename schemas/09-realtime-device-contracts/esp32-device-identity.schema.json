{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://iotables.net/schemas/09-realtime-device-contracts/esp32-device-identity.schema.json",
  "title": "IoTable ESP32 Device Identity Schema",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "document",
    "purpose",
    "identity_model",
    "responsibilities",
    "device_authentication",
    "pairing_flow",
    "realtime_connection",
    "server_qr_authority",
    "health_and_observability",
    "security_rules",
    "forbidden_behavior",
    "open_decisions",
    "done_when"
  ],
  "properties": {
    "document": { "$ref": "#/$defs/document" },
    "purpose": { "$ref": "#/$defs/object_record" },
    "identity_model": { "$ref": "#/$defs/object_record" },
    "responsibilities": { "$ref": "#/$defs/object_record" },
    "device_authentication": { "$ref": "#/$defs/object_record" },
    "pairing_flow": { "$ref": "#/$defs/object_record" },
    "realtime_connection": { "$ref": "#/$defs/object_record" },
    "server_qr_authority": { "$ref": "#/$defs/object_record" },
    "health_and_observability": { "$ref": "#/$defs/object_record" },
    "security_rules": { "type": "array", "items": { "$ref": "#/$defs/security_rule" } },
    "forbidden_behavior": { "$ref": "#/$defs/string_array" },
    "open_decisions": { "type": "array" },
    "done_when": { "$ref": "#/$defs/string_array" }
  },
  "$defs": {
    "string_array": { "type": "array", "items": { "type": "string", "minLength": 1 } },
    "object_record": { "type": "object", "additionalProperties": true, "minProperties": 1 },
    "document": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "title", "project", "version", "language", "format", "schema_required", "schema_file", "status"],
      "properties": {
        "id": { "type": "string", "const": "09-realtime-device-contracts.esp32-device-identity" },
        "title": { "type": "string", "minLength": 1 },
        "project": { "type": "string", "const": "IoTable" },
        "version": { "type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$" },
        "language": { "type": "string", "const": "en" },
        "format": { "type": "string", "const": "yaml" },
        "schema_required": { "type": "boolean", "const": true },
        "schema_file": { "type": "string", "const": "schemas/09-realtime-device-contracts/esp32-device-identity.schema.json" },
        "status": { "type": "string", "enum": ["draft", "accepted", "superseded"] }
      }
    },
    "security_rule": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "rule"],
      "properties": {
        "id": { "type": "string", "pattern": "^EDI-[0-9]{3}$" },
        "rule": { "type": "string", "minLength": 1 }
      }
    }
  }
}
