{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://iotables.net/schemas/12-operations-deployment/health-checks.schema.json",
  "title": "IoTable Health Checks Schema",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "document",
    "purpose",
    "endpoint_contract",
    "liveness_policy",
    "readiness_policy",
    "response_contract",
    "exposure_policy",
    "release_gate_integration",
    "source_alignment",
    "forbidden_behavior",
    "open_questions",
    "done_when"
  ],
  "properties": {
    "document": { "$ref": "#/$defs/document" },
    "purpose": { "$ref": "#/$defs/purpose" },
    "endpoint_contract": { "$ref": "#/$defs/endpoint_contract" },
    "liveness_policy": { "$ref": "#/$defs/liveness_policy" },
    "readiness_policy": { "$ref": "#/$defs/readiness_policy" },
    "response_contract": { "$ref": "#/$defs/response_contract" },
    "exposure_policy": { "$ref": "#/$defs/exposure_policy" },
    "release_gate_integration": { "$ref": "#/$defs/release_gate_integration" },
    "source_alignment": { "$ref": "#/$defs/source_alignment" },
    "forbidden_behavior": { "$ref": "#/$defs/string_array" },
    "open_questions": {
      "type": "array",
      "items": { "$ref": "#/$defs/open_question" }
    },
    "done_when": { "$ref": "#/$defs/string_array" }
  },
  "$defs": {
    "document": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "title", "project", "version", "language", "format", "schema_required", "schema_file", "status"],
      "properties": {
        "id": { "type": "string", "const": "12-operations-deployment.health-checks" },
        "title": { "type": "string", "minLength": 1 },
        "project": { "type": "string", "const": "IoTable" },
        "version": { "type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$" },
        "language": { "type": "string", "const": "en" },
        "format": { "type": "string", "const": "yaml" },
        "schema_required": { "type": "boolean", "const": true },
        "schema_file": { "type": "string", "const": "schemas/12-operations-deployment/health-checks.schema.json" },
        "status": { "type": "string", "enum": ["draft", "accepted", "superseded"] }
      }
    },
    "purpose": {
      "type": "object",
      "additionalProperties": false,
      "required": ["rule", "applies_to"],
      "properties": {
        "rule": { "type": "string", "minLength": 1 },
        "applies_to": { "$ref": "#/$defs/string_array" }
      }
    },
    "endpoint_contract": {
      "type": "object",
      "additionalProperties": false,
      "required": ["endpoints", "rules"],
      "properties": {
        "endpoints": {
          "type": "array",
          "minItems": 3,
          "items": { "$ref": "#/$defs/endpoint" }
        },
        "rules": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/rule_record" }
        }
      }
    },
    "endpoint": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "path", "classification", "purpose"],
      "properties": {
        "id": { "type": "string", "enum": ["health_alias", "health_live", "health_ready"] },
        "path": { "type": "string", "enum": ["/health", "/health/live", "/health/ready"] },
        "classification": { "type": "string", "enum": ["liveness_alias", "liveness", "readiness"] },
        "purpose": { "type": "string", "minLength": 1 }
      }
    },
    "liveness_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["endpoint", "dependency_checks_allowed", "success_condition", "failure_meaning", "rules"],
      "properties": {
        "endpoint": { "type": "string", "const": "/health/live" },
        "dependency_checks_allowed": { "type": "boolean", "const": false },
        "success_condition": { "type": "string", "minLength": 1 },
        "failure_meaning": { "type": "string", "minLength": 1 },
        "rules": { "type": "array", "items": { "$ref": "#/$defs/live_rule_record" } }
      }
    },
    "readiness_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["endpoint", "scope_resolution", "required_checks", "rules"],
      "properties": {
        "endpoint": { "type": "string", "const": "/health/ready" },
        "scope_resolution": { "$ref": "#/$defs/scope_resolution" },
        "required_checks": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/readiness_check" }
        },
        "rules": { "type": "array", "items": { "$ref": "#/$defs/ready_rule_record" } }
      }
    },
    "scope_resolution": {
      "type": "object",
      "additionalProperties": false,
      "required": ["platform_host", "tenant_host", "rule"],
      "properties": {
        "platform_host": { "$ref": "#/$defs/readiness_scope" },
        "tenant_host": { "$ref": "#/$defs/readiness_scope" },
        "rule": { "type": "string", "minLength": 1 }
      }
    },
    "readiness_scope": {
      "type": "object",
      "additionalProperties": false,
      "required": ["host", "readiness_scope", "database_checks"],
      "properties": {
        "host": { "type": "string", "minLength": 1 },
        "readiness_scope": { "type": "string", "enum": ["platform", "tenant"] },
        "database_checks": { "$ref": "#/$defs/string_array" }
      }
    },
    "readiness_check": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "component_type", "failure_status", "rule"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "component_type": { "type": "string", "enum": ["configuration", "datastore", "background_worker"] },
        "failure_status": { "type": "string", "enum": ["warn", "fail"] },
        "rule": { "type": "string", "minLength": 1 }
      }
    },
    "response_contract": {
      "type": "object",
      "additionalProperties": false,
      "required": ["content_type", "status_values", "required_fields", "http_status_mapping", "rules"],
      "properties": {
        "content_type": { "type": "string", "const": "application/health+json" },
        "status_values": { "$ref": "#/$defs/string_array" },
        "required_fields": { "$ref": "#/$defs/string_array" },
        "http_status_mapping": {
          "type": "object",
          "additionalProperties": false,
          "required": ["pass", "warn", "fail"],
          "properties": {
            "pass": { "type": "integer", "const": 200 },
            "warn": { "type": "integer", "const": 200 },
            "fail": { "type": "integer", "const": 503 }
          }
        },
        "rules": { "type": "array", "items": { "$ref": "#/$defs/response_rule_record" } }
      }
    },
    "exposure_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["public_exposure", "rules"],
      "properties": {
        "public_exposure": {
          "type": "object",
          "additionalProperties": false,
          "required": ["health_alias", "health_live", "health_ready"],
          "properties": {
            "health_alias": { "type": "string", "enum": ["allowed", "restricted", "forbidden"] },
            "health_live": { "type": "string", "enum": ["allowed", "restricted", "forbidden"] },
            "health_ready": { "type": "string", "enum": ["allowed", "restricted", "forbidden"] }
          }
        },
        "rules": { "type": "array", "items": { "$ref": "#/$defs/exposure_rule_record" } }
      }
    },
    "release_gate_integration": {
      "type": "object",
      "additionalProperties": false,
      "required": ["required_checks", "rules"],
      "properties": {
        "required_checks": { "$ref": "#/$defs/string_array" },
        "rules": { "type": "array", "items": { "$ref": "#/$defs/release_gate_rule_record" } }
      }
    },
    "source_alignment": {
      "type": "object",
      "additionalProperties": false,
      "required": ["authoritative_project_documents", "external_references", "reference_fit_rule"],
      "properties": {
        "authoritative_project_documents": { "$ref": "#/$defs/string_array" },
        "external_references": {
          "type": "array",
          "items": { "$ref": "#/$defs/external_reference" }
        },
        "reference_fit_rule": { "type": "string", "minLength": 1 }
      }
    },
    "external_reference": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "source", "url", "usage"],
      "properties": {
        "id": { "type": "string", "pattern": "^EXT-HC-[0-9]{3}$" },
        "source": { "type": "string", "minLength": 1 },
        "url": { "type": "string", "pattern": "^https://.+" },
        "usage": { "type": "string", "minLength": 1 }
      }
    },
    "open_question": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "question", "owner"],
      "properties": {
        "id": { "type": "string", "pattern": "^HC-Q-[0-9]{3}$" },
        "question": { "type": "string", "minLength": 1 },
        "owner": { "type": "string", "minLength": 1 }
      }
    },
    "rule_record": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "rule"],
      "properties": {
        "id": { "type": "string", "pattern": "^HC-[0-9]{3}$" },
        "rule": { "type": "string", "minLength": 1 }
      }
    },
    "live_rule_record": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "rule"],
      "properties": {
        "id": { "type": "string", "pattern": "^HC-LIVE-[0-9]{3}$" },
        "rule": { "type": "string", "minLength": 1 }
      }
    },
    "ready_rule_record": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "rule"],
      "properties": {
        "id": { "type": "string", "pattern": "^HC-READY-[0-9]{3}$" },
        "rule": { "type": "string", "minLength": 1 }
      }
    },
    "response_rule_record": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "rule"],
      "properties": {
        "id": { "type": "string", "pattern": "^HC-RESP-[0-9]{3}$" },
        "rule": { "type": "string", "minLength": 1 }
      }
    },
    "exposure_rule_record": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "rule"],
      "properties": {
        "id": { "type": "string", "pattern": "^HC-EXP-[0-9]{3}$" },
        "rule": { "type": "string", "minLength": 1 }
      }
    },
    "release_gate_rule_record": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "rule"],
      "properties": {
        "id": { "type": "string", "pattern": "^HC-RG-[0-9]{3}$" },
        "rule": { "type": "string", "minLength": 1 }
      }
    },
    "string_array": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    }
  }
}
