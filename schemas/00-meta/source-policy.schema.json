{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://iotables.net/schemas/00-meta/source-policy.schema.json",
  "title": "IoTable Source Policy Schema",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "document",
    "purpose",
    "source_authority_levels",
    "source_usage_rules",
    "source_record_format",
    "conflict_resolution",
    "prohibited_source_handling",
    "done_when"
  ],
  "properties": {
    "document": { "$ref": "#/$defs/document" },
    "purpose": { "$ref": "#/$defs/object_record" },
    "source_authority_levels": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/source_authority_level" }
    },
    "source_usage_rules": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/rule_record" }
    },
    "source_record_format": { "$ref": "#/$defs/source_record_format" },
    "conflict_resolution": { "$ref": "#/$defs/object_record" },
    "prohibited_source_handling": { "$ref": "#/$defs/string_array" },
    "done_when": { "$ref": "#/$defs/string_array" }
  },
  "$defs": {
    "string_array": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "object_record": {
      "type": "object",
      "additionalProperties": true,
      "minProperties": 1
    },
    "document": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "title", "project", "version", "language", "format", "schema_required", "schema_file", "status"],
      "properties": {
        "id": { "type": "string", "const": "00-meta.source-policy" },
        "title": { "type": "string", "minLength": 1 },
        "project": { "type": "string", "const": "IoTable" },
        "version": { "type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$" },
        "language": { "type": "string", "const": "en" },
        "format": { "type": "string", "const": "yaml" },
        "schema_required": { "type": "boolean", "const": true },
        "schema_file": { "type": "string", "const": "schemas/00-meta/source-policy.schema.json" },
        "status": { "type": "string", "enum": ["draft", "accepted", "superseded"] }
      }
    },
    "source_authority_level": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "authority", "can_define_product_behavior", "can_define_technical_constraint", "approval_required", "description"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "authority": { "type": "string", "enum": ["binding", "high", "medium_high", "medium", "low", "none"] },
        "can_define_product_behavior": { "type": "boolean" },
        "can_define_technical_constraint": { "type": "boolean" },
        "approval_required": { "type": "boolean" },
        "description": { "type": "string", "minLength": 1 }
      }
    },
    "rule_record": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "rule"],
      "properties": {
        "id": { "type": "string", "pattern": "^SUR-[0-9]{3}$" },
        "rule": { "type": "string", "minLength": 1 }
      }
    },
    "source_record_format": {
      "type": "object",
      "additionalProperties": false,
      "required": ["required_fields", "optional_fields"],
      "properties": {
        "required_fields": { "$ref": "#/$defs/string_array" },
        "optional_fields": { "$ref": "#/$defs/string_array" }
      }
    }
  }
}
