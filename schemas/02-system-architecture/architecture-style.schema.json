{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://iotables.net/schemas/02-system-architecture/architecture-style.schema.json",
  "title": "IoTable Architecture Style Schema",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "document",
    "purpose",
    "selected_architecture",
    "rationale",
    "module_boundary_rules",
    "clean_architecture_rules",
    "runtime_topology",
    "inter_module_communication",
    "background_processing",
    "migration_policy",
    "service_extraction_policy",
    "open_decisions",
    "done_when"
  ],
  "properties": {
    "document": { "$ref": "#/$defs/document" },
    "purpose": { "$ref": "#/$defs/object_record" },
    "selected_architecture": { "$ref": "#/$defs/object_record" },
    "rationale": { "$ref": "#/$defs/object_record" },
    "module_boundary_rules": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/rule_record_mbr" } },
    "clean_architecture_rules": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/rule_record_car" } },
    "runtime_topology": { "$ref": "#/$defs/object_record" },
    "inter_module_communication": { "$ref": "#/$defs/object_record" },
    "background_processing": { "$ref": "#/$defs/object_record" },
    "migration_policy": { "$ref": "#/$defs/object_record" },
    "service_extraction_policy": { "$ref": "#/$defs/object_record" },
    "open_decisions": { "type": "array", "items": { "$ref": "#/$defs/open_decision" } },
    "done_when": { "$ref": "#/$defs/string_array" }
  },
  "$defs": {
    "string_array": { "type": "array", "items": { "type": "string", "minLength": 1 } },
    "object_record": { "type": "object", "additionalProperties": true, "minProperties": 1 },
    "document": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "title", "project", "version", "language", "format", "schema_required", "schema_file", "status"],
      "properties": {
        "id": { "type": "string", "const": "02-system-architecture.architecture-style" },
        "title": { "type": "string", "minLength": 1 },
        "project": { "type": "string", "const": "IoTable" },
        "version": { "type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$" },
        "language": { "type": "string", "const": "en" },
        "format": { "type": "string", "const": "yaml" },
        "schema_required": { "type": "boolean", "const": true },
        "schema_file": { "type": "string", "const": "schemas/02-system-architecture/architecture-style.schema.json" },
        "status": { "type": "string", "enum": ["draft", "accepted", "superseded"] }
      }
    },
    "rule_record_mbr": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "rule"],
      "properties": {
        "id": { "type": "string", "pattern": "^MBR-[0-9]{3}$" },
        "rule": { "type": "string", "minLength": 1 }
      }
    },
    "rule_record_car": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "rule"],
      "properties": {
        "id": { "type": "string", "pattern": "^CAR-[0-9]{3}$" },
        "rule": { "type": "string", "minLength": 1 }
      }
    },
    "open_decision": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "topic", "status"],
      "properties": {
        "id": { "type": "string", "pattern": "^AS-[0-9]{3}$" },
        "topic": { "type": "string", "minLength": 1 },
        "status": { "type": "string", "enum": ["open", "accepted", "rejected"] }
      }
    }
  }
}
