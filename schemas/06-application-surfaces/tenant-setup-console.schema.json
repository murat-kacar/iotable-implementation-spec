{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://iotables.net/schemas/06-application-surfaces/tenant-setup-console.schema.json",
  "title": "IoTable Tenant Setup Console Schema",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "document",
    "purpose",
    "surface",
    "business_profile_defaults",
    "operating_defaults",
    "table_model",
    "station_model",
    "default_seed_station",
    "menu_category_model",
    "menu_item_model",
    "station_routing_policy",
    "staff_setup",
    "device_setup",
    "tenant_setup_flow",
    "setup_steps",
    "default_seed_tables",
    "operations_activation_gates",
    "post_activation_behavior",
    "forbidden_behavior",
    "open_decisions",
    "done_when"
  ],
  "properties": {
    "document": { "$ref": "#/$defs/document" },
    "purpose": { "$ref": "#/$defs/object_record" },
    "surface": { "$ref": "#/$defs/object_record" },
    "business_profile_defaults": { "$ref": "#/$defs/object_record" },
    "operating_defaults": { "$ref": "#/$defs/object_record" },
    "table_model": { "$ref": "#/$defs/object_record" },
    "station_model": { "$ref": "#/$defs/object_record" },
    "default_seed_station": { "$ref": "#/$defs/object_record" },
    "menu_category_model": { "$ref": "#/$defs/object_record" },
    "menu_item_model": { "$ref": "#/$defs/object_record" },
    "station_routing_policy": { "$ref": "#/$defs/object_record" },
    "staff_setup": { "$ref": "#/$defs/object_record" },
    "device_setup": { "$ref": "#/$defs/object_record" },
    "tenant_setup_flow": { "$ref": "#/$defs/object_record" },
    "setup_steps": { "type": "array", "items": { "$ref": "#/$defs/object_record" } },
    "default_seed_tables": { "$ref": "#/$defs/object_record" },
    "operations_activation_gates": { "$ref": "#/$defs/object_record" },
    "post_activation_behavior": { "$ref": "#/$defs/object_record" },
    "forbidden_behavior": { "$ref": "#/$defs/string_array" },
    "open_decisions": { "type": "array" },
    "done_when": { "$ref": "#/$defs/string_array" }
  },
  "$defs": {
    "string_array": { "type": "array", "items": { "type": "string", "minLength": 1 } },
    "object_record": { "type": "object", "additionalProperties": true, "minProperties": 1 },
    "document": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "title", "project", "version", "language", "format", "schema_required", "schema_file", "status"],
      "properties": {
        "id": { "type": "string", "const": "06-application-surfaces.tenant-setup-console" },
        "title": { "type": "string", "minLength": 1 },
        "project": { "type": "string", "const": "IoTable" },
        "version": { "type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$" },
        "language": { "type": "string", "const": "en" },
        "format": { "type": "string", "const": "yaml" },
        "schema_required": { "type": "boolean", "const": true },
        "schema_file": { "type": "string", "const": "schemas/06-application-surfaces/tenant-setup-console.schema.json" },
        "status": { "type": "string", "enum": ["draft", "accepted", "superseded"] }
      }
    }
  }
}
