{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://iotables.net/schemas/06-application-surfaces/platform-settings-catalog.schema.json",
  "title": "IoTable Platform Settings Catalog Schema",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "document",
    "purpose",
    "settings_policy",
    "editable_settings",
    "read_only_settings",
    "settings_ui",
    "platform_audit_events",
    "forbidden_behavior",
    "open_decisions",
    "done_when"
  ],
  "properties": {
    "document": { "$ref": "#/$defs/document" },
    "purpose": { "$ref": "#/$defs/object_record" },
    "settings_policy": { "$ref": "#/$defs/object_record" },
    "editable_settings": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/editable_setting" } },
    "read_only_settings": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/read_only_setting" } },
    "settings_ui": { "$ref": "#/$defs/object_record" },
    "platform_audit_events": { "type": "array", "items": { "$ref": "#/$defs/audit_event" } },
    "forbidden_behavior": { "$ref": "#/$defs/string_array" },
    "open_decisions": { "type": "array" },
    "done_when": { "$ref": "#/$defs/string_array" }
  },
  "$defs": {
    "string_array": { "type": "array", "items": { "type": "string", "minLength": 1 } },
    "object_record": { "type": "object", "additionalProperties": true, "minProperties": 1 },
    "document": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "title", "project", "version", "language", "format", "schema_required", "schema_file", "status"],
      "properties": {
        "id": { "type": "string", "const": "06-application-surfaces.platform-settings-catalog" },
        "title": { "type": "string", "minLength": 1 },
        "project": { "type": "string", "const": "IoTable" },
        "version": { "type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$" },
        "language": { "type": "string", "const": "en" },
        "format": { "type": "string", "const": "yaml" },
        "schema_required": { "type": "boolean", "const": true },
        "schema_file": { "type": "string", "const": "schemas/06-application-surfaces/platform-settings-catalog.schema.json" },
        "status": { "type": "string", "enum": ["draft", "accepted", "superseded"] }
      }
    },
    "editable_setting": {
      "type": "object",
      "additionalProperties": true,
      "required": ["id", "type", "default", "validation", "applies_to", "retroactive"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "type": { "type": "string", "minLength": 1 },
        "default": {},
        "validation": { "type": "string", "minLength": 1 },
        "applies_to": { "type": "string", "minLength": 1 },
        "retroactive": { "type": "boolean" }
      }
    },
    "read_only_setting": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "value", "reason"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "value": {},
        "reason": { "type": "string", "minLength": 1 }
      }
    },
    "audit_event": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "actor", "required_fields"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "actor": { "type": "string", "minLength": 1 },
        "required_fields": { "$ref": "#/$defs/string_array" }
      }
    }
  }
}
