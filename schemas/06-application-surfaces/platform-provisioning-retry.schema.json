{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://iotables.net/schemas/06-application-surfaces/platform-provisioning-retry.schema.json",
  "title": "IoTable Platform Provisioning Retry Schema",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "document",
    "purpose",
    "provisioning_retry_policy",
    "provisioning_steps",
    "job_status_model",
    "platform_ui_behavior",
    "retry_execution_rules",
    "platform_audit_events",
    "forbidden_behavior",
    "open_decisions",
    "done_when"
  ],
  "properties": {
    "document": { "$ref": "#/$defs/document" },
    "purpose": { "$ref": "#/$defs/object_record" },
    "provisioning_retry_policy": { "$ref": "#/$defs/object_record" },
    "provisioning_steps": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/provisioning_step" } },
    "job_status_model": { "$ref": "#/$defs/object_record" },
    "platform_ui_behavior": { "$ref": "#/$defs/object_record" },
    "retry_execution_rules": { "$ref": "#/$defs/object_record" },
    "platform_audit_events": { "type": "array", "items": { "$ref": "#/$defs/audit_event" } },
    "forbidden_behavior": { "$ref": "#/$defs/string_array" },
    "open_decisions": { "type": "array" },
    "done_when": { "$ref": "#/$defs/string_array" }
  },
  "$defs": {
    "string_array": { "type": "array", "items": { "type": "string", "minLength": 1 } },
    "object_record": { "type": "object", "additionalProperties": true, "minProperties": 1 },
    "document": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "title", "project", "version", "language", "format", "schema_required", "schema_file", "status"],
      "properties": {
        "id": { "type": "string", "const": "06-application-surfaces.platform-provisioning-retry" },
        "title": { "type": "string", "minLength": 1 },
        "project": { "type": "string", "const": "IoTable" },
        "version": { "type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$" },
        "language": { "type": "string", "const": "en" },
        "format": { "type": "string", "const": "yaml" },
        "schema_required": { "type": "boolean", "const": true },
        "schema_file": { "type": "string", "const": "schemas/06-application-surfaces/platform-provisioning-retry.schema.json" },
        "status": { "type": "string", "enum": ["draft", "accepted", "superseded"] }
      }
    },
    "provisioning_step": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "retryable"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "retryable": { "type": "boolean" },
        "reason": { "type": "string" },
        "idempotency_required": { "type": "boolean" }
      }
    },
    "audit_event": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "actor", "required_fields"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "actor": { "type": "string", "minLength": 1 },
        "required_fields": { "$ref": "#/$defs/string_array" }
      }
    }
  }
}
