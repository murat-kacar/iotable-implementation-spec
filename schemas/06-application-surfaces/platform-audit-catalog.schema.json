{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://iotables.net/schemas/06-application-surfaces/platform-audit-catalog.schema.json",
  "title": "IoTable Platform Audit Catalog Schema",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "document",
    "purpose",
    "platform_audit_policy",
    "platform_audit_record_contract",
    "event_catalog",
    "excluded_events",
    "platform_audit_ui",
    "forbidden_behavior",
    "open_decisions",
    "done_when"
  ],
  "properties": {
    "document": { "$ref": "#/$defs/document" },
    "purpose": { "$ref": "#/$defs/object_record" },
    "platform_audit_policy": { "$ref": "#/$defs/object_record" },
    "platform_audit_record_contract": { "$ref": "#/$defs/object_record" },
    "event_catalog": { "$ref": "#/$defs/object_record" },
    "excluded_events": { "type": "array", "items": { "$ref": "#/$defs/excluded_event" } },
    "platform_audit_ui": { "$ref": "#/$defs/object_record" },
    "forbidden_behavior": { "$ref": "#/$defs/string_array" },
    "open_decisions": { "type": "array" },
    "done_when": { "$ref": "#/$defs/string_array" }
  },
  "$defs": {
    "string_array": { "type": "array", "items": { "type": "string", "minLength": 1 } },
    "object_record": { "type": "object", "additionalProperties": true, "minProperties": 1 },
    "document": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "title", "project", "version", "language", "format", "schema_required", "schema_file", "status"],
      "properties": {
        "id": { "type": "string", "const": "06-application-surfaces.platform-audit-catalog" },
        "title": { "type": "string", "minLength": 1 },
        "project": { "type": "string", "const": "IoTable" },
        "version": { "type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$" },
        "language": { "type": "string", "const": "en" },
        "format": { "type": "string", "const": "yaml" },
        "schema_required": { "type": "boolean", "const": true },
        "schema_file": { "type": "string", "const": "schemas/06-application-surfaces/platform-audit-catalog.schema.json" },
        "status": { "type": "string", "enum": ["draft", "accepted", "superseded"] }
      }
    },
    "excluded_event": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "reason"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "reason": { "type": "string", "minLength": 1 }
      }
    }
  }
}
