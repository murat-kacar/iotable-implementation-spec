{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://iotables.net/schemas/03-domain/module-inventory.schema.json",
  "title": "IoTable Module Inventory Schema",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "document",
    "purpose",
    "module_classification",
    "modules",
    "external_or_excluded_modules",
    "module_dependency_rules",
    "open_decisions",
    "done_when"
  ],
  "properties": {
    "document": { "$ref": "#/$defs/document" },
    "purpose": { "$ref": "#/$defs/object_record" },
    "module_classification": { "$ref": "#/$defs/object_record" },
    "modules": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/module" } },
    "external_or_excluded_modules": { "type": "array", "items": { "$ref": "#/$defs/excluded_module" } },
    "module_dependency_rules": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/rule_record" } },
    "open_decisions": { "type": "array", "items": { "$ref": "#/$defs/open_decision" } },
    "done_when": { "$ref": "#/$defs/string_array" }
  },
  "$defs": {
    "string_array": { "type": "array", "items": { "type": "string", "minLength": 1 } },
    "object_record": { "type": "object", "additionalProperties": true, "minProperties": 1 },
    "document": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "title", "project", "version", "language", "format", "schema_required", "schema_file", "status"],
      "properties": {
        "id": { "type": "string", "const": "03-domain.module-inventory" },
        "title": { "type": "string", "minLength": 1 },
        "project": { "type": "string", "const": "IoTable" },
        "version": { "type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$" },
        "language": { "type": "string", "const": "en" },
        "format": { "type": "string", "const": "yaml" },
        "schema_required": { "type": "boolean", "const": true },
        "schema_file": { "type": "string", "const": "schemas/03-domain/module-inventory.schema.json" },
        "status": { "type": "string", "enum": ["draft", "accepted", "superseded"] }
      }
    },
    "module": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "name", "scope", "responsibility", "owns_data", "owns_surfaces", "owns_api_families", "depends_on", "done_when"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "name": { "type": "string", "minLength": 1 },
        "scope": { "type": "string", "enum": ["platform_scope", "tenant_scope", "shared_scope", "external_scope"] },
        "responsibility": { "type": "string", "minLength": 1 },
        "owns_data": { "$ref": "#/$defs/string_array" },
        "owns_surfaces": { "$ref": "#/$defs/string_array" },
        "owns_api_families": { "$ref": "#/$defs/string_array" },
        "depends_on": { "$ref": "#/$defs/string_array" },
        "source_documents": { "$ref": "#/$defs/string_array" },
        "explicit_non_goals": { "$ref": "#/$defs/string_array" },
        "status": { "type": "string", "enum": ["draft", "accepted", "requires_decision"] },
        "open_decision_refs": { "$ref": "#/$defs/string_array" },
        "done_when": { "$ref": "#/$defs/string_array" }
      }
    },
    "excluded_module": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "status", "reason"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "status": { "type": "string", "const": "excluded" },
        "reason": { "type": "string", "minLength": 1 }
      }
    },
    "rule_record": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "rule"],
      "properties": {
        "id": { "type": "string", "pattern": "^MDR-[0-9]{3}$" },
        "rule": { "type": "string", "minLength": 1 }
      }
    },
    "open_decision": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "topic", "status"],
      "properties": {
        "id": { "type": "string", "pattern": "^MI-[0-9]{3}$" },
        "topic": { "type": "string", "minLength": 1 },
        "status": { "type": "string", "enum": ["open", "accepted", "rejected"] }
      }
    }
  }
}
