{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://iotables.net/schemas/03-domain/customer-order-session-workflow.schema.json",
  "title": "IoTable Customer Order Session Workflow Schema",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "document",
    "purpose",
    "access_model",
    "session_lifetime",
    "session_states",
    "commands",
    "workflows",
    "anti_manipulation_rules",
    "customer_identity_policy",
    "domain_events",
    "forbidden_behavior",
    "open_decisions",
    "done_when"
  ],
  "properties": {
    "document": { "type": "object", "additionalProperties": true },
    "purpose": { "type": "object", "additionalProperties": true },
    "access_model": { "type": "object", "additionalProperties": true },
    "session_lifetime": { "type": "object", "additionalProperties": true },
    "session_states": { "type": "object", "additionalProperties": true },
    "commands": { "type": "array", "items": { "type": "object", "additionalProperties": true } },
    "workflows": { "type": "object", "additionalProperties": true },
    "anti_manipulation_rules": { "type": "array", "items": { "type": "string" } },
    "customer_identity_policy": { "type": "object", "additionalProperties": true },
    "domain_events": { "type": "array", "items": { "type": "string" } },
    "forbidden_behavior": { "type": "array", "items": { "type": "string" } },
    "open_decisions": { "type": "array" },
    "done_when": { "type": "array", "items": { "type": "string" } }
  }
}
