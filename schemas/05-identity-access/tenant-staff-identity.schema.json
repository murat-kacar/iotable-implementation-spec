{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://iotables.net/schemas/05-identity-access/tenant-staff-identity.schema.json",
  "title": "IoTable Tenant Staff Identity and Activation Schema",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "document",
    "purpose",
    "identity_scope",
    "activation_model",
    "staff_invite_policy",
    "password_policy",
    "two_factor_policy",
    "login_policy",
    "staff_lifecycle",
    "data_contract_expectations",
    "security_and_audit",
    "forbidden_behavior",
    "open_decisions",
    "done_when"
  ],
  "properties": {
    "document": { "type": "object", "additionalProperties": true },
    "purpose": { "type": "object", "additionalProperties": true },
    "identity_scope": { "type": "object", "additionalProperties": true },
    "activation_model": { "type": "object", "additionalProperties": true },
    "staff_invite_policy": { "type": "object", "additionalProperties": true },
    "password_policy": { "type": "object", "additionalProperties": true },
    "two_factor_policy": { "type": "object", "additionalProperties": true },
    "login_policy": { "type": "object", "additionalProperties": true },
    "staff_lifecycle": { "type": "object", "additionalProperties": true },
    "data_contract_expectations": { "type": "object", "additionalProperties": true },
    "security_and_audit": { "type": "object", "additionalProperties": true },
    "forbidden_behavior": { "type": "array", "items": { "type": "string" } },
    "open_decisions": { "type": "array" },
    "done_when": { "type": "array", "items": { "type": "string" } }
  }
}
