{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://iotables.net/schemas/07-api-contracts/tenant-staff-identity-api.schema.json",
  "title": "IoTable Tenant Staff Identity API Contracts Schema",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "document",
    "purpose",
    "api_policy",
    "route_families",
    "common_contract_rules",
    "endpoints",
    "request_response_contracts",
    "security_and_audit",
    "forbidden_behavior",
    "open_decisions",
    "done_when"
  ],
  "properties": {
    "document": { "type": "object", "additionalProperties": true },
    "purpose": { "type": "object", "additionalProperties": true },
    "api_policy": { "type": "object", "additionalProperties": true },
    "route_families": { "type": "object", "additionalProperties": true },
    "common_contract_rules": { "type": "object", "additionalProperties": true },
    "endpoints": { "type": "object", "additionalProperties": true },
    "request_response_contracts": { "type": "object", "additionalProperties": true },
    "security_and_audit": { "type": "object", "additionalProperties": true },
    "forbidden_behavior": { "type": "array", "items": { "type": "string" } },
    "open_decisions": { "type": "array" },
    "done_when": { "type": "array", "items": { "type": "string" } }
  }
}
