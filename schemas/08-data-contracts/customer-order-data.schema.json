{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://iotables.net/schemas/08-data-contracts/customer-order-data.schema.json",
  "title": "IoTable Customer Order Data Contracts Schema",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "document",
    "purpose",
    "isolation_principle",
    "common_columns",
    "qr_token_policy",
    "customer_session_policy",
    "order_model",
    "price_snapshot_policy",
    "tables",
    "submit_transaction_rules",
    "forbidden_behavior",
    "open_decisions",
    "done_when"
  ],
  "properties": {
    "document": { "type": "object", "additionalProperties": true },
    "purpose": { "type": "object", "additionalProperties": true },
    "isolation_principle": { "type": "object", "additionalProperties": true },
    "common_columns": { "type": "object", "additionalProperties": true },
    "qr_token_policy": { "type": "object", "additionalProperties": true },
    "customer_session_policy": { "type": "object", "additionalProperties": true },
    "order_model": { "type": "object", "additionalProperties": true },
    "price_snapshot_policy": { "type": "object", "additionalProperties": true },
    "tables": { "type": "object", "additionalProperties": true },
    "submit_transaction_rules": { "type": "object", "additionalProperties": true },
    "forbidden_behavior": { "type": "array", "items": { "type": "string" } },
    "open_decisions": { "type": "array" },
    "done_when": { "type": "array", "items": { "type": "string" } }
  }
}
