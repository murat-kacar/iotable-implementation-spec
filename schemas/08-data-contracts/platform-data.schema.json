{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://iotables.net/schemas/08-data-contracts/platform-data.schema.json",
  "title": "IoTable Platform Data Contracts Schema",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "document",
    "purpose",
    "platform_database_policy",
    "schemas",
    "tables",
    "forbidden_tables",
    "constraint_rules",
    "open_decisions",
    "done_when"
  ],
  "properties": {
    "document": { "$ref": "#/$defs/document" },
    "purpose": { "$ref": "#/$defs/object_record" },
    "platform_database_policy": { "$ref": "#/$defs/object_record" },
    "schemas": { "$ref": "#/$defs/object_record" },
    "tables": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/table" } },
    "forbidden_tables": { "$ref": "#/$defs/string_array" },
    "constraint_rules": { "type": "array", "items": { "$ref": "#/$defs/rule_record" } },
    "open_decisions": { "type": "array" },
    "done_when": { "$ref": "#/$defs/string_array" }
  },
  "$defs": {
    "string_array": { "type": "array", "items": { "type": "string", "minLength": 1 } },
    "object_record": { "type": "object", "additionalProperties": true, "minProperties": 1 },
    "document": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "title", "project", "version", "language", "format", "schema_required", "schema_file", "status"],
      "properties": {
        "id": { "type": "string", "const": "08-data-contracts.platform-data" },
        "title": { "type": "string", "minLength": 1 },
        "project": { "type": "string", "const": "IoTable" },
        "version": { "type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$" },
        "language": { "type": "string", "const": "en" },
        "format": { "type": "string", "const": "yaml" },
        "schema_required": { "type": "boolean", "const": true },
        "schema_file": { "type": "string", "const": "schemas/08-data-contracts/platform-data.schema.json" },
        "status": { "type": "string", "enum": ["draft", "accepted", "superseded"] }
      }
    },
    "table": {
      "type": "object",
      "additionalProperties": true,
      "required": ["name", "purpose", "owner_module", "columns"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "purpose": { "type": "string", "minLength": 1 },
        "owner_module": { "type": "string", "minLength": 1 },
        "append_only": { "type": "boolean" },
        "columns": { "type": "array", "minItems": 1, "items": { "type": "object", "additionalProperties": true } },
        "indexes": { "type": "array", "items": { "type": "object", "additionalProperties": true } },
        "primary_key": { "$ref": "#/$defs/string_array" }
      }
    },
    "rule_record": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "rule"],
      "properties": {
        "id": { "type": "string", "pattern": "^PDC-[0-9]{3}$" },
        "rule": { "type": "string", "minLength": 1 }
      }
    }
  }
}
