{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://iotables.net/schemas/04-tenancy/tenant-lifecycle-provisioning.schema.json",
  "title": "IoTable Tenant Lifecycle and Provisioning Schema",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "document",
    "purpose",
    "lifecycle_statuses",
    "lifecycle_vs_operations_activation",
    "provisioning_flow",
    "slug_policy",
    "database_naming_policy",
    "seed_data",
    "owner_activation_invite",
    "provisioning_success_criteria",
    "provisioning_failure",
    "retry_policy",
    "schema_versioning",
    "forbidden_behavior",
    "open_decisions",
    "done_when"
  ],
  "properties": {
    "document": { "type": "object", "additionalProperties": true },
    "purpose": { "type": "object", "additionalProperties": true },
    "lifecycle_statuses": { "type": "object", "additionalProperties": true },
    "lifecycle_vs_operations_activation": { "type": "object", "additionalProperties": true },
    "provisioning_flow": { "type": "object", "additionalProperties": true },
    "slug_policy": { "type": "object", "additionalProperties": true },
    "database_naming_policy": { "type": "object", "additionalProperties": true },
    "seed_data": { "type": "object", "additionalProperties": true },
    "owner_activation_invite": { "type": "object", "additionalProperties": true },
    "provisioning_success_criteria": { "type": "object", "additionalProperties": true },
    "provisioning_failure": { "type": "object", "additionalProperties": true },
    "retry_policy": { "type": "object", "additionalProperties": true },
    "schema_versioning": { "type": "object", "additionalProperties": true },
    "forbidden_behavior": { "type": "array", "items": { "type": "string" } },
    "open_decisions": { "type": "array" },
    "done_when": { "type": "array", "items": { "type": "string" } }
  }
}
