{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://iotables.net/schemas/01-product/product-baseline.schema.json",
  "title": "IoTable Product Baseline Schema",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "document",
    "product_identity",
    "multi_tenancy",
    "platform_scope",
    "platform_database_scope",
    "provisioning_lifecycle",
    "tenant_database_schema_change_orchestration",
    "route_namespace_standard",
    "authentication_authorization",
    "payment_checkout_scope",
    "customer_ordering_session_baseline",
    "device_baseline",
    "stakeholders",
    "application_surface_families",
    "api_families",
    "product_decision_references",
    "open_product_decisions",
    "done_when"
  ],
  "properties": {
    "document": { "$ref": "#/$defs/document" },
    "product_identity": { "$ref": "#/$defs/product_identity" },
    "multi_tenancy": { "$ref": "#/$defs/multi_tenancy" },
    "platform_scope": { "$ref": "#/$defs/object_record" },
    "platform_database_scope": { "$ref": "#/$defs/scope_record" },
    "provisioning_lifecycle": { "$ref": "#/$defs/provisioning_lifecycle" },
    "tenant_database_schema_change_orchestration": { "$ref": "#/$defs/object_record" },
    "route_namespace_standard": { "$ref": "#/$defs/object_record" },
    "authentication_authorization": { "$ref": "#/$defs/object_record" },
    "payment_checkout_scope": { "$ref": "#/$defs/object_record" },
    "customer_ordering_session_baseline": { "$ref": "#/$defs/object_record" },
    "device_baseline": { "$ref": "#/$defs/object_record" },
    "stakeholders": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/stakeholder" } },
    "application_surface_families": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/surface_family" } },
    "api_families": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/surface_family" } },
    "product_decision_references": { "type": "array", "items": { "$ref": "#/$defs/object_record" } },
    "open_product_decisions": { "type": "array", "items": { "$ref": "#/$defs/open_product_decision" } },
    "done_when": { "$ref": "#/$defs/string_array" }
  },
  "$defs": {
    "string_array": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } },
    "object_record": { "type": "object", "additionalProperties": true, "minProperties": 1 },
    "document": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "title", "project", "version", "language", "format", "schema_required", "schema_file", "status"],
      "properties": {
        "id": { "type": "string", "const": "01-product.product-baseline" },
        "title": { "type": "string", "minLength": 1 },
        "project": { "type": "string", "const": "IoTable" },
        "version": { "type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$" },
        "language": { "type": "string", "const": "en" },
        "format": { "type": "string", "const": "yaml" },
        "schema_required": { "type": "boolean", "const": true },
        "schema_file": { "type": "string", "const": "schemas/01-product/product-baseline.schema.json" },
        "status": { "type": "string", "enum": ["draft", "accepted", "superseded"] }
      }
    },
    "product_identity": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "definition", "platform_domain", "tenant_domain_pattern"],
      "properties": {
        "name": { "type": "string", "const": "IoTable" },
        "definition": { "type": "string", "const": "IoTable is a multi-tenant cafe and restaurant operations platform." },
        "platform_domain": { "type": "string", "const": "platform.iotables.net" },
        "tenant_domain_pattern": { "type": "string", "const": "{tenant}.iotables.net" }
      }
    },
    "multi_tenancy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["tenant_resolution", "platform_domain", "tenant_domain_pattern", "data_isolation_model", "platform_database", "tenant_database_pattern", "rules"],
      "properties": {
        "tenant_resolution": { "type": "string", "const": "subdomain" },
        "platform_domain": { "type": "string", "const": "platform.iotables.net" },
        "tenant_domain_pattern": { "type": "string", "const": "{tenant}.iotables.net" },
        "data_isolation_model": { "type": "string", "const": "database_per_tenant" },
        "platform_database": { "type": "string", "const": "iotable_platform" },
        "tenant_database_pattern": { "type": "string", "const": "iotable_tenant_{tenantSlug}" },
        "rules": { "$ref": "#/$defs/string_array" }
      }
    },
    "scope_record": {
      "type": "object",
      "additionalProperties": false,
      "required": ["owns", "does_not_own"],
      "properties": {
        "owns": { "$ref": "#/$defs/string_array" },
        "does_not_own": { "$ref": "#/$defs/string_array" }
      }
    },
    "provisioning_lifecycle": {
      "type": "object",
      "additionalProperties": false,
      "required": ["tenant_statuses", "creation_flow", "status_behavior"],
      "properties": {
        "tenant_statuses": { "$ref": "#/$defs/string_array" },
        "creation_flow": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/provisioning_step" } },
        "status_behavior": { "$ref": "#/$defs/object_record" }
      }
    },
    "provisioning_step": {
      "type": "object",
      "additionalProperties": false,
      "required": ["step", "id", "actor", "result"],
      "properties": {
        "step": { "type": "integer", "minimum": 1 },
        "id": { "type": "string", "minLength": 1 },
        "actor": { "type": "string", "minLength": 1 },
        "result": { "type": "string", "minLength": 1 }
      }
    },
    "stakeholder": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "primary_goal"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "primary_goal": { "type": "string", "minLength": 1 }
      }
    },
    "surface_family": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "audience", "route_family"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "audience": { "$ref": "#/$defs/string_array" },
        "route_family": { "$ref": "#/$defs/string_array" }
      }
    },
    "open_product_decision": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "topic", "status"],
      "properties": {
        "id": { "type": "string", "pattern": "^PD-[0-9]{3}$" },
        "topic": { "type": "string", "minLength": 1 },
        "status": { "type": "string", "enum": ["open", "accepted", "rejected"] }
      }
    }
  }
}
